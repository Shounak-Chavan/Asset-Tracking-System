# Asset Tracking System - Frontend Environment Configuration
# Copy this file to .env.local and configure for your environment
# DO NOT commit the .env.local file to version control

# ============ API Configuration ============
# Backend API base URL - adjust based on your environment
# For local development: http://localhost:8000
# For production: https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:8000

# ============ Optional: Analytics ============
# VITE_ANALYTICS_ID=your_analytics_id

# ============ Optional: Feature Flags ============
# VITE_ENABLE_BETA_FEATURES=false

# ============ Build Configuration ============
# VITE_SOURCE_MAP=true
