# Asset Tracking System - Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to version control

# ============ Application ============
APP_NAME="Asset Tracking System"

# ============ JWT Configuration ============
# Generate strong secret keys using: python -c "import secrets; print(secrets.token_urlsafe(32))"
ACCESS_TOKEN_SECRET_KEY=your_secure_access_token_secret_key_here
REFRESH_TOKEN_SECRET_KEY=your_secure_refresh_token_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============ Database Configuration ============
# PostgreSQL connection URL
# Format: postgresql+asyncpg://username:password@localhost:5432/database_name
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/asset_db

# ============ Admin Credentials ============
# These are used for initial admin user creation
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=secure_password_here
ADMIN_FULL_NAME=Admin User

# ============ Optional: Email Configuration ============
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SENDER_EMAIL=your_email@gmail.com

# ============ Optional: Payment Gateway (Razorpay) ============
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ============ Optional: AWS S3 for uploads ============
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_S3_BUCKET=your_bucket_name
# AWS_REGION=us-east-1
